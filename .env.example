# API Configuration
API_BASE_URL=http://localhost:8000/api
API_TIMEOUT=30000

# Firebase Configuration (for Google Auth)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
FIREBASE_APP_ID=your_firebase_app_id

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Stripe Configuration for Payments
STRIPE_PUBLIC_KEY=your_stripe_public_key
STRIPE_MERCHANT_ID=your_stripe_merchant_id
XENDIT_SECRET_KEY=your_xendit_secret_key
XENDIT_PUBLIC_KEY=your_xendit_public_key
XENDIT_WEBHOOK_TOKEN=your_webhook_verification_token

# App Configuration
APP_ENV=development
LOG_LEVEL=debug

APP_SCHEME=missfit
SUCCESS_REDIRECT_URL=missfit://payment-success
FAILURE_REDIRECT_URL=missfit://payment-failed
